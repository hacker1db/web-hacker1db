{
  "name": "hacker1db-blog",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "ci": "bun run check && bun run lint && bun run build"
  },
  "dependencies": {
    "@sveltejs/adapter-vercel": "^5.7.3",
    "@sveltejs/kit": "^2.21.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "date-fns": "^3.6.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "mdsvex": "^0.12.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "shiki": "^3.4.2",
    "svelte": "^5.33.12",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.8",
    "@types/node": "^22.15.0",
    "eslint": "^9.36.0",
    "eslint-plugin-svelte": "^3.9.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.2.1",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
